    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Test script example",
          "pm.test(\"Status code is 200\", function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "// For successful responses",
          "pm.test(\"Response has success property\", function () {",
          "    var jsonData = pm.response.json();",
          "    pm.expect(jsonData.success).to.eql(true);",
          "});",
          "",
          "// Store auth token from login response",
          "if (pm.request.name === \"Login User\" && pm.response.code === 200) {",
          "    var jsonData = pm.response.json();",
          "    pm.collectionVariables.set(\"auth_token\", jsonData.token);",
          "    pm.collectionVariables.set(\"organization_id\", jsonData.user.organization_id);",
          "    pm.collectionVariables.set(\"user_id\", jsonData.user.id);",
          "}",
          "",
          "// Store department ID from creation response",
          "if (pm.request.name === \"Create Department\" && pm.response.code === 201) {",
          "    var jsonData = pm.response.json();",
          "    pm.collectionVariables.set(\"department_id\", jsonData.department.id);",
          "}"
        ]
      }
    }
